# ─── ALO AI — Variáveis de Ambiente ───
# Copie este arquivo para .env e preencha os valores

# Supabase (obrigatório para auth e banco de dados)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY

# API (backend Node.js/Fastify — quando estiver pronto)
VITE_API_URL=http://localhost:3001

# WhatsApp via Evolution API (opcional)
VITE_EVOLUTION_URL=http://localhost:8080
VITE_EVOLUTION_KEY=SUA_API_KEY

# OpenAI / Claude (para o Agente IA)
# Nunca exponha no frontend — use apenas no backend
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
